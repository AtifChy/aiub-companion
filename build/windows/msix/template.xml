<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="aiub-companion.exe"
        Arguments=""
        InstallLocation="C:\Program Files\AIUB Companion\AIUB Companion">
    </Installer>
    <PackageInformation
        PackageName="AIUB Companion"
        PackageDisplayName="AIUB Companion"
        PublisherName="CN=AIUB Companion"
        PublisherDisplayName="AIUB Companion"
        Version="0.1.0.0"
        PackageDescription="AIUB Companion">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="io.github.atifchy.aiub-companion"
                Description="AIUB Companion"
                DisplayName="AIUB Companion"
                ExecutableName="aiub-companion.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>AIUB Companion</DisplayName>
            <PublisherDisplayName>AIUB Companion</PublisherDisplayName>
            <Description>AIUB Companion</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="aiub-companion.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
