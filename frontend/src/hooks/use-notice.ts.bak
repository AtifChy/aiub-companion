import type { Notice } from "@bindings/model";
import {
  GetNoticeDetails,
  GetNotices,
  SyncNotices,
  ToggleNoticeRead,
} from "@bindings/service/noticeservice";
import { Events } from "@wailsio/runtime";
import React, { useEffect, useReducer, useState } from "react";
import { toast } from "sonner";

const PAGE_SIZE = 30;

export type Category =
  | "all"
  | "general"
  | "admission"
  | "exam"
  | "registration"
  | "internship"
  | "scholarship"
  | "payment"
  | "holiday";

interface FilterState {
  search: string;
  category: Category;
  urgent: boolean;
  pinned: boolean;
  unread: boolean;
}

type FilterAction =
  | { type: "SET_SEARCH"; payload: string }
  | { type: "SET_CATEGORY"; payload: Category }
  | { type: "SET_URGENT"; payload: boolean }
  | { type: "SET_PINNED"; payload: boolean }
  | { type: "SET_UNREAD"; payload: boolean }
  | { type: "RESET_FILTERS" }
  | { type: "CLEAR_SEARCH_CATEGORY" };

function filterReducer(state: FilterState, action: FilterAction): FilterState {
  switch (action.type) {
    case "SET_SEARCH":
      return { ...state, search: action.payload };
    case "SET_CATEGORY":
      return { ...state, category: action.payload };
    case "SET_URGENT":
      return { ...state, urgent: action.payload };
    case "SET_PINNED":
      return { ...state, pinned: action.payload };
    case "SET_UNREAD":
      return { ...state, unread: action.payload };
    case "RESET_FILTERS":
      return { ...state, urgent: false, pinned: false, unread: false };
    case "CLEAR_SEARCH_CATEGORY":
      return { ...state, search: "", category: "all" };
    default:
      return state;
  }
}

const initialState: FilterState = {
  search: "",
  category: "all",
  urgent: false,
  pinned: false,
  unread: false,
};

export function useNotice(search: string) {
  const [filters, dispatch] = useReducer(filterReducer, initialState);

  const [notices, setNotices] = useState<Notice[]>([]);
  const [loadingList, setLoadingList] = useState(true);
  const [selectedId, setSelectedId] = useState<string | null>(null);
  const [detail, setDetail] = useState<Notice | null>(null);
  const [loadingDetail, setLoadingDetail] = useState(false);

  const [syncing, setSyncing] = useState(false);
  const [fetchError, setError] = useState<string | null>(null);

  const unreadCount = notices.filter((n) => !n.isRead).length;

  const fetchNotices = async () => {
    setLoadingList(true);
    setError(null);
    try {
      const category = filters.category === "all" ? "" : filters.category;
      const data = await GetNotices(
        category,
        search,
        filters.unread || null,
        filters.pinned || null,
        filters.unread || null,
        PAGE_SIZE,
        0,
      );
      setNotices(data ?? []);
    } catch (err) {
      toast.error("Failed to fetch notices", {
        description: err instanceof Error ? err.message : String(err),
      });
      setError(err instanceof Error ? err.message : String(err));
    } finally {
      setLoadingList(false);
    }
  };

  useEffect(() => {
    fetchNotices();
  }, [filters.category, filters.unread, filters.pinned, search]);

  // Sync event
  useEffect(() => {
    const cleanup = Events.On("notices:synced", async (event) => {
      const count = event.data;
      toast.success(`Synced ${count} notice${count !== 1 ? "s" : ""}`);
      await fetchNotices();
    });
    return cleanup;
  }, []);

  // Fetch notice details
  useEffect(() => {
    if (!selectedId) {
      setDetail(null);
      return;
    }
    let cancelled = false;
    setLoadingDetail(true);
    GetNoticeDetails(selectedId)
      .then((data) => {
        if (cancelled || !data) return;
        setDetail(data);
      })
      .catch((err) =>
        toast.error("Failed to fetch notice details", {
          description: err instanceof Error ? err.message : String(err),
        }),
      )
      .finally(() => !cancelled && setLoadingDetail(false));
    return () => {
      cancelled = true;
    };
  }, [selectedId]);

  const handleSelect = async (notice: Notice) => {
    setSelectedId(notice.id);
    setDetail(notice);
    if (!notice.isRead) {
      try {
        await ToggleNoticeRead(notice.id, true);
        setNotices((prev) =>
          prev.map((n) =>
            n.id === notice.id ? patch(n, { isRead: true }) : n,
          ),
        );
        setDetail((prev) =>
          prev?.id === notice.id ? patch(prev, { isRead: true }) : prev,
        );
      } catch (err) {
        toast.error("Failed to mark notice as read", {
          description: err instanceof Error ? err.message : String(err),
        });
      }
    }
  };

  const handleToggleRead = async () => {
    if (!detail) return;
    const next = !detail.isRead;
    try {
      await ToggleNoticeRead(detail.id, next);
      setDetail((prev) => (prev ? patch(prev, { isRead: next }) : prev));
    } catch (err) {
      toast.error("Failed to mark notice as read", {
        description: err instanceof Error ? err.message : String(err),
      });
    }
  };

  const handleTogglePin = async (
    id: string,
    current: boolean,
    e?: React.MouseEvent,
  ) => {
    e?.preventDefault();
    const next = !current;
    try {
      await ToggleNoticeRead(id, next);
      setNotices((prev) =>
        prev.map((n) => (n.id === id ? patch(n, { isPinned: next }) : n)),
      );
      setDetail((prev) =>
        prev?.id === id ? patch(prev, { isPinned: next }) : prev,
      );
    } catch (err) {
      toast.error("Failed to toggle pin", {
        description: err instanceof Error ? err.message : String(err),
      });
    }
  };

  const handleSync = async () => {
    setSyncing(true);
    try {
      const count = await SyncNotices(PAGE_SIZE);
      if (count > 0) {
        toast.success("Synced notices", {
          description: `Synced ${count} notice${count !== 1 ? "s" : ""}`,
        });
      } else {
        toast.info("No new notices to sync");
      }
    } catch (err) {
      toast.error("Failed to sync notices", {
        description: err instanceof Error ? err.message : String(err),
      });
    } finally {
      setSyncing(false);
    }
  };

  return {
    notices,
    loadingList,
    selectedId,
    detail,
    loadingDetail,
    unreadCount,
    filters,
    syncing,
    fetchError,
    fetchNotices,
    handleSelect,
    handleToggleRead,
    handleTogglePin,
    handleSync,
  };
}

export function patch<T extends object>(obj: T, changes: Partial<T>): T {
  return Object.assign(Object.create(Object.getPrototypeOf(obj)), obj, changes);
}
