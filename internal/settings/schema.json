{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/Settings",
  "$defs": {
    "Settings": {
      "properties": {
        "theme": {
          "type": "string",
          "enum": [
            "light",
            "dark",
            "system"
          ]
        },
        "log_level": {
          "type": "string",
          "enum": [
            "DEBUG",
            "INFO",
            "WARN",
            "ERROR"
          ]
        },
        "sync": {
          "$ref": "#/$defs/synchronization"
        },
        "launch": {
          "$ref": "#/$defs/launch"
        },
        "notifications": {
          "$ref": "#/$defs/notification"
        },
        "window": {
          "$ref": "#/$defs/WindowState"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "theme",
        "log_level",
        "sync",
        "launch",
        "notifications",
        "window"
      ]
    },
    "WindowState": {
      "properties": {
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        },
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        },
        "maximized": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "width",
        "height",
        "x",
        "y",
        "maximized"
      ]
    },
    "launch": {
      "properties": {
        "start_minimized": {
          "type": "boolean"
        },
        "close_to_tray": {
          "type": "boolean"
        },
        "restore_window": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "start_minimized",
        "close_to_tray",
        "restore_window"
      ]
    },
    "notification": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "enabled"
      ]
    },
    "synchronization": {
      "properties": {
        "interval_minutes": {
          "type": "integer"
        },
        "fetch_count": {
          "type": "integer"
        },
        "on_startup": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "interval_minutes",
        "fetch_count",
        "on_startup"
      ]
    }
  }
}