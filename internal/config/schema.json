{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/Config",
  "$defs": {
    "Config": {
      "properties": {
        "theme": {
          "type": "string",
          "enum": [
            "light",
            "dark",
            "system"
          ]
        },
        "log_level": {
          "type": "string",
          "enum": [
            "DEBUG",
            "INFO",
            "WARN",
            "ERROR"
          ]
        },
        "sync": {
          "$ref": "#/$defs/synchronization"
        },
        "launch": {
          "$ref": "#/$defs/launch"
        },
        "notifications": {
          "$ref": "#/$defs/notification"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "theme",
        "log_level",
        "sync",
        "launch",
        "notifications"
      ]
    },
    "launch": {
      "properties": {
        "start_minimized": {
          "type": "boolean"
        },
        "close_to_tray": {
          "type": "boolean"
        },
        "keep_alive": {
          "type": "boolean"
        },
        "restore_window": {
          "type": "boolean"
        },
        "sidebar_open": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "start_minimized",
        "close_to_tray",
        "keep_alive",
        "restore_window",
        "sidebar_open"
      ]
    },
    "notification": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "enabled"
      ]
    },
    "synchronization": {
      "properties": {
        "interval_minutes": {
          "type": "integer"
        },
        "fetch_count": {
          "type": "integer"
        },
        "on_startup": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "interval_minutes",
        "fetch_count",
        "on_startup"
      ]
    }
  }
}