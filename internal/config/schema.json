{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/Config",
  "$defs": {
    "Config": {
      "properties": {
        "appearance": {
          "$ref": "#/$defs/appearance"
        },
        "updates": {
          "$ref": "#/$defs/updates"
        },
        "logging": {
          "$ref": "#/$defs/logging"
        },
        "sync": {
          "$ref": "#/$defs/sync_"
        },
        "launch": {
          "$ref": "#/$defs/launch"
        },
        "notifications": {
          "$ref": "#/$defs/notification"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "appearance",
        "updates",
        "logging",
        "sync",
        "launch",
        "notifications"
      ]
    },
    "appearance": {
      "properties": {
        "theme": {
          "type": "string",
          "enum": [
            "light",
            "dark",
            "system"
          ]
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "theme"
      ]
    },
    "launch": {
      "properties": {
        "auto_start": {
          "type": "boolean"
        },
        "start_minimized": {
          "type": "boolean"
        },
        "close_to_tray": {
          "type": "boolean"
        },
        "keep_alive": {
          "type": "boolean"
        },
        "restore_window": {
          "type": "boolean"
        },
        "sidebar_open": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "auto_start",
        "start_minimized",
        "close_to_tray",
        "keep_alive",
        "restore_window",
        "sidebar_open"
      ]
    },
    "logging": {
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "DEBUG",
            "INFO",
            "WARN",
            "ERROR"
          ]
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "level"
      ]
    },
    "notification": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "enabled"
      ]
    },
    "sync_": {
      "properties": {
        "interval": {
          "type": "integer"
        },
        "fetch_count": {
          "type": "integer"
        },
        "on_startup": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "interval",
        "fetch_count",
        "on_startup"
      ]
    },
    "updates": {
      "properties": {
        "interval": {
          "type": "string",
          "enum": [
            "never",
            "daily",
            "weekly",
            "monthly"
          ]
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "interval"
      ]
    }
  }
}